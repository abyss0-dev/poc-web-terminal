#cloud-config
hostname: vm1
fqdn: vm1
ssh_pwauth: true
disable_root: false
users:
  - name: poc
    plain_text_passwd: poc
    lock_passwd: false
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: [sudo]
chpasswd:
  expire: false
  users:
    - name: poc
      password: poc
      type: text
